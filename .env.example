# 火山引擎 API Key（必填）
# 从 https://console.volcengine.com/ark 获取
VOLCENGINE_API_KEY=your-api-key-here

# 可选：模型 ID，需与火山方舟控制台创建的推理接入点一致
# 例如 doubao-seed-2.0-lite、doubao-seed-2.0-pro
VOLCENGINE_MODEL=doubao-seed-2.0-lite

# 可选：API Base URL
# 对话接口用 api/v3，代码接口用 api/coding/v3
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
